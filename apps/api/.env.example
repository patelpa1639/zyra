# Fastify Server
PORT=3000
NODE_ENV=development
LOG_LEVEL=info

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# JWT
JWT_SECRET=your-jwt-secret-key-change-in-production
JWT_EXPIRATION=24h

# Anthropic / Claude API
ANTHROPIC_API_KEY=sk-ant-your-api-key-here

# OAuth - Strava
STRAVA_CLIENT_ID=your-strava-client-id
STRAVA_CLIENT_SECRET=your-strava-client-secret
STRAVA_REDIRECT_URI=http://localhost:3000/api/auth/oauth/strava/callback

# OAuth - Garmin
GARMIN_CLIENT_ID=your-garmin-client-id
GARMIN_CLIENT_SECRET=your-garmin-client-secret
GARMIN_REDIRECT_URI=http://localhost:3000/api/auth/oauth/garmin/callback

# OAuth - Apple Health (configured via Apple Developer)
APPLE_HEALTH_TEAM_ID=your-apple-team-id
APPLE_HEALTH_KEY_ID=your-apple-key-id

# Encryption (for storing sensitive OAuth tokens)
ENCRYPTION_KEY=your-32-character-encryption-key-here

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/zyra

# Email (optional, for notifications)
RESEND_API_KEY=your-resend-api-key-optional
SENDGRID_API_KEY=your-sendgrid-api-key-optional

# Frontend URLs
WEB_URL=http://localhost:3001
MOBILE_URL=exp://localhost:8081

# Sentry (optional, for error tracking)
SENTRY_DSN=your-sentry-dsn-optional

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# CORS
CORS_ORIGIN=http://localhost:3001,http://localhost:3000
